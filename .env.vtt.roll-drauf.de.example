FLASK_ENV=production
FLASK_DEBUG=0

SECRET_KEY=replace-with-long-random-secret
JWT_SECRET_KEY=replace-with-long-random-jwt-secret

DATABASE_URL=postgresql://vtt:vtt@db:5432/vtt
REDIS_URL=redis://redis:6379/0
SOCKETIO_MESSAGE_QUEUE=redis://redis:6379/0
RATELIMIT_STORAGE_URL=redis://redis:6379/1
RATELIMIT_STORAGE_URI=redis://redis:6379/1

CORS_ORIGINS=https://vtt.roll-drauf.de,http://vtt.roll-drauf.de
AUTO_CREATE_SCHEMA=true
LOG_JSON=true
METRICS_ENABLED=true
VOICE_ENABLED=false
USE_SESSION_SOCKET_V2=false
